# SessionGrid Environment Configuration
# Copy to .env and fill in values

# Database
DATABASE_URL=postgresql+asyncpg://sessiongrid:sessiongrid@localhost:5432/sessiongrid
DATABASE_URL_SYNC=postgresql://sessiongrid:sessiongrid@localhost:5432/sessiongrid

# Redis
REDIS_URL=redis://localhost:6379/0

# Storage
STORAGE_ROOT=./storage
UPLOAD_MAX_SIZE_MB=200

# Analysis Pipeline
DEMUCS_MODEL=htdemucs
SAMPLE_RATE=44100
RANDOM_SEED=42

# Pipeline Version (bump on any pipeline change)
PIPELINE_VERSION=0.1.0

# CORS
CORS_ORIGINS=http://localhost:3000

# Debug
DEBUG=true
